# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Example: mongodb+srv://<user>:<password>@cluster0.abcde.mongodb.net/cybernauts
MONGO_URI=mongodb://localhost:27017/cybernauts

# Security
# Replace with a long random string in production
JWT_SECRET=development_secret_key_12345
JWT_EXPIRE=7d
FRONTEND_URL=http://localhost:5173
